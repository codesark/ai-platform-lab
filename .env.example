# Copy to .env and fill in real values.  NEVER commit .env (it is gitignored).
#   cp .env.example .env

# --- AI service ---
AI_SERVICE_API_KEY=change-me-local-dev-key      # clients send this as the X-API-Key header
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:8080           # CORS allow-list (the WASM UI origin)

# --- Database (Postgres + pgvector) ---
# Local (host) default. In docker-compose the host is "db" (see compose env override).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_platform

# --- Inference: Gemini (hosted) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768                               # must match the VECTOR(...) column in schema.sql

# --- Inference provider selection (alternate backend) ---
INFERENCE_PROVIDER=gemini                        # gemini | vllm | local (offline, no API key)
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Retrieval ---
RETRIEVAL_TOP_K=5

# --- Langfuse (tracing) --- tracing no-ops unless both keys are set
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Evals ---
# EVAL_JUDGE=1   # also run LLM-judge answer metrics (faithfulness, relevancy); needs a real provider
